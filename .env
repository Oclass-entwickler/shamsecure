# ============================================
# ShamSecure - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Site Information
SITE_NAME=ShamSecure
SITE_NAME_AR=شام سكيور
SITE_URL=
SITE_EMAIL=info@shamsecure.com
# Contact Information
PHONE_PRIMARY=+963 944496363
PHONE_SECONDARY=+963 944496363
EMAIL_INFO=info@shamsecure.com
EMAIL_SALES=info@shamsecure.com
EMAIL_SUPPORT=info@shamsecure.com
ADDRESS_CITY=دمشق
ADDRESS_STREET=دمشق
ADDRESS_COUNTRY=سوريا

# Social Media Links
FACEBOOK_URL=لاحقآ
INSTAGRAM_URL=لاحقآ
LINKEDIN_URL=لاحقآ
TWITTER_URL=لاحقآ

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=ShamSecure
SMTP_FROM_EMAIL=noreply@shamsecure.sy

# Email Recipients
ADMIN_EMAIL=hasankeisar@gmail.com
QUOTE_EMAIL=hasankeisar@gmail.com
CONTACT_EMAIL=hasankeisar@gmail.com

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345
ADMIN_SECRET_KEY=12345

# API Configuration
API_KEY=generate-random-api-key-here
API_ENABLED=true

# Google Services (Optional)
GOOGLE_ANALYTICS_ID=
GOOGLE_MAPS_API_KEY=

# Security
SESSION_SECRET=change-this-to-random-string
JWT_SECRET=change-this-to-random-string

# Production Settings
NODE_ENV=production
PORT=3000

# Database (if needed later)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=shamsecure
