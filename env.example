# ============================================
# ShamSecure - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Site Information
SITE_NAME=ShamSecure
SITE_NAME_AR=شام سكيور
SITE_URL=https://shamsecure.sy
SITE_EMAIL=info@shamsecure.sy

# Contact Information
PHONE_PRIMARY=+963 11 123 4567
PHONE_SECONDARY=+963 11 123 4568
EMAIL_INFO=info@shamsecure.sy
EMAIL_SALES=sales@shamsecure.sy
EMAIL_SUPPORT=support@shamsecure.sy
ADDRESS_CITY=دمشق
ADDRESS_STREET=شارع الرئيسي، مبنى رقم 123
ADDRESS_COUNTRY=سوريا

# Social Media Links
FACEBOOK_URL=https://facebook.com/shamsecure
INSTAGRAM_URL=https://instagram.com/shamsecure
LINKEDIN_URL=https://linkedin.com/company/shamsecure
TWITTER_URL=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=ShamSecure
SMTP_FROM_EMAIL=noreply@shamsecure.sy

# Email Recipients
ADMIN_EMAIL=admin@shamsecure.sy
QUOTE_EMAIL=quotes@shamsecure.sy
CONTACT_EMAIL=contact@shamsecure.sy

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SECRET_KEY=change-this-secret-key-to-random-string

# API Configuration
API_KEY=generate-random-api-key-here
API_ENABLED=true

# Google Services (Optional)
GOOGLE_ANALYTICS_ID=
GOOGLE_MAPS_API_KEY=

# Security
SESSION_SECRET=change-this-to-random-string
JWT_SECRET=change-this-to-random-string

# Production Settings
NODE_ENV=production
PORT=3000

# Database (if needed later)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=shamsecure
